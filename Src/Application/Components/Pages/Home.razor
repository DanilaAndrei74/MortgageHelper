@page "/"


@code{
    [Inject]
    public AppState AppState { get; set; }

    [Parameter]
    public List<Installment> Installments { get; set; } 


    protected override void OnInitialized()
    {

        AppState.Mortgage.SetInterestRates(30, 5, 8)
                         .SetInsurance(0.02)
                         .GenerateInstallments(10000, 120)
                         .CalculateDerivates();

        AppState.Initialize();
    }
}
